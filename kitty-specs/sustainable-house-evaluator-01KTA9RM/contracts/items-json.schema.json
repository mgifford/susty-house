{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Sustainable House Evaluator — items.json",
  "description": "Schema for src/data/items.json: upgrade item catalogue with categories, items, weights, and capacity thresholds.",
  "type": "object",
  "required": ["categories"],
  "properties": {
    "categories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["key", "label", "description", "items"],
        "properties": {
          "key": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "label": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "items": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["key", "label", "guidance", "weight", "budget_min", "skill_min", "time_min", "ambition_levels", "slider_labels"],
              "properties": {
                "key": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
                "label": { "type": "string", "minLength": 1 },
                "guidance": { "type": "string", "minLength": 1 },
                "weight": { "type": "integer", "minimum": 1, "maximum": 10 },
                "budget_min": { "type": "string", "enum": ["limited", "moderate", "substantial", "major"] },
                "skill_min": { "type": "string", "enum": ["novice", "basic_diy", "experienced", "trade"] },
                "time_min": { "type": "string", "enum": ["limited", "weekends", "extended", "hired"] },
                "ambition_levels": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "type": "string", "enum": ["light_touch", "meaningful", "significant", "deep_green"] }
                },
                "slider_labels": {
                  "type": "array",
                  "minItems": 6,
                  "maxItems": 6,
                  "items": { "type": "string", "minLength": 1 }
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
